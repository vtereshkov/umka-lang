type list = struct {
  value: int
  next: ^list
}

fn test1() {
  var p: ^list

  for i := 0; i < 1000000; i++ {
    n := new(list)
    n.value = i
    n.next = p
    p = n
  }
}

fn test2() {
  leaksan(2)
  
  var p, tail: ^list

  for i := 0; i < 10; i++ {
    n := new(list)
    n.value = i
    n.next = p
    p = n
    if tail == null {
      tail = p
    }
  }

  tail.next = p  // cycle
}

fn contrived(arr: ^[]int, x: int): int {
  i := len(arr^)
  arr^ = append(arr^, 0)
  dummy := make([]int, 100000)
  if x != 0 {
    arr^[i] = contrived(arr, x-1)
  }
  return x + 1
}

fn test3() {
  for i := 0; i < 1000; i++ {
    arr := []int{}
    contrived(&arr, 10)
  }
}

fn test*() {
  test1()
  test2()
  test3()
  printf("Ok")
}

fn main() {
	test()
}