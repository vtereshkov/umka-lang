// Section 59: arithmetic identities for mixed signed/unsigned
// ----------------------------------------------------------------------------

fn section_mixed_arith() {
    banner("mixed arithmetic")

    var u: uint32 = 1000
    var i: int32 = 500
    var s: int = int(u) - int(i)
    check(s == 500, "u-i as int")

    var u64: uint = 0
    u64 = u64 - 1
    var lo: uint32 = uint32(u64 & 0xFFFFFFFF)
    check(lo == 0xFFFFFFFF, "uint low bits")

    var v: uint32 = 0xFFFFFFFF
    check(v == 0xFFFFFFFF, "uint32 all ones")

    printf("mixed arithmetic: OK\n")
}

// ----------------------------------------------------------------------------
// Section 60: pseudo-random shuffle via Fisher-Yates
// ----------------------------------------------------------------------------

fn section_shuffle() {
    banner("shuffle")

    srand(61)
    n := 200
    a := make([]int, n)
    for i in a {
        a[i] = i
    }

    for i := n - 1; i > 0; i-- {
        j := int(rand32() % uint32(i + 1))
        a[i], a[j] = a[j], a[i]
    }

    seen := make([]bool, n)
    for _, v in a {
        check(v >= 0 && v < n, "shuffle range")
        check(!seen[v], "shuffle unique")
        seen[v] = true
    }
    for _, b in seen {
        check(b, "shuffle covers all")
    }

    printf("shuffle: OK\n")
}

// ----------------------------------------------------------------------------
// Section 61: simple stack via dynamic array
// ----------------------------------------------------------------------------

fn section_stack() {
    banner("stack")

    stk := []int{}
    for i := 0; i < 1000; i++ {
        stk = append(stk, i)
    }
    check(len(stk) == 1000, "stack push count")

    for i := 999; i >= 0; i-- {
        top := stk[len(stk) - 1]
        check(top == i, "stack pop value")
        stk = slice(stk, 0, len(stk) - 1)
    }
    check(len(stk) == 0, "stack empty after pops")

    printf("stack: OK\n")
}

// ----------------------------------------------------------------------------
// Section 62: queue via two stacks
// ----------------------------------------------------------------------------

type Queue = struct {
    inS:  []int
    outS: []int
}

fn (q: ^Queue) push(v: int) {
    q.inS = append(q.inS, v)
}

fn (q: ^Queue) pop(): (int, bool) {
    if len(q.outS) == 0 {
        for i := len(q.inS) - 1; i >= 0; i-- {
            q.outS = append(q.outS, q.inS[i])
        }
        q.inS = []int{}
    }
    if len(q.outS) == 0 {
        return 0, false
    }
    v := q.outS[len(q.outS) - 1]
    q.outS = slice(q.outS, 0, len(q.outS) - 1)
    return v, true
}

fn section_queue() {
    banner("queue")

    q := new(Queue)
    for i := 0; i < 100; i++ {
        q.push(i)
    }
    for i := 0; i < 100; i++ {
        v, ok := q.pop()
        check(ok, "queue ok")
        check(v == i, "queue order")
    }
    _, ok := q.pop()
    check(!ok, "queue empty")

    printf("queue: OK\n")
}

