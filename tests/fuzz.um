// ----------------------------------------------------------------------------
// Section 46: comparison operators across types
// ----------------------------------------------------------------------------

type CmpP = struct { x, y: int }

fn section_comparisons() {
    banner("comparisons")

    check(1.0 < 1.1, "real lt")
    check(1.1 > 1.0, "real gt")
    check(1.0 == 1.0, "real eq")
    check(1.0 != 1.1, "real neq")

    check(real(1) < 1.5, "int<real")
    check(1.5 > real(1), "real>int")

    p1 := CmpP{1, 2}
    p2 := CmpP{1, 2}
    p3 := CmpP{1, 3}
    check(p1 == p2, "struct eq")
    check(p1 != p3, "struct neq")

    a1 := [3]int{1, 2, 3}
    a2 := [3]int{1, 2, 3}
    a3 := [3]int{1, 2, 4}
    check(a1 == a2, "array eq")
    check(a1 != a3, "array neq")

    printf("comparisons: OK\n")
}

// ----------------------------------------------------------------------------
// Section 47: combining everything in a mini-program (k-NN-ish)
// ----------------------------------------------------------------------------

type Point2 = struct {
    x, y: real
    lbl:  str
}

fn distance(a, b: Point2): real {
    dx := a.x - b.x
    dy := a.y - b.y
    return sqrt(dx*dx + dy*dy)
}

fn nearest(pts: []Point2, q: Point2): Point2 {
    best := pts[0]
    bestD := distance(pts[0], q)
    for i := 1; i < len(pts); i++ {
        d := distance(pts[i], q)
        if d < bestD {
            bestD = d
            best = pts[i]
        }
    }
    return best
}

fn section_mini_program() {
    banner("mini program (nearest-neighbor)")

    srand(47)
    pts := []Point2{}
    for i := 0; i < 200; i++ {
        pts = append(pts, Point2{
            x:   randReal() / 1e3,
            y:   randReal() / 1e3,
            lbl: sprintf("p%d", i),
        })
    }

    for trial := 0; trial < 20; trial++ {
        q := Point2{randReal() / 1e3, randReal() / 1e3, "q"}
        got := nearest(pts, q)
        gotD := distance(got, q)
        for _, p in pts {
            check(distance(p, q) >= gotD - 1e-9, "nn min")
        }
    }

    printf("mini program: OK\n")
}

