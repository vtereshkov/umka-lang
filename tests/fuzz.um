// ----------------------------------------------------------------------------
// Section 65: large recursion depth
// ----------------------------------------------------------------------------

fn deepRecur(n: int): int {
    if n == 0 {
        return 0
    }
    return 1 + deepRecur(n - 1)
}

fn section_deep_recursion() {
    banner("deep recursion")
    check(deepRecur(500) == 500, "deep recursion 500")
    check(deepRecur(2000) == 2000, "deep recursion 2000")
    printf("deep recursion: OK\n")
}

