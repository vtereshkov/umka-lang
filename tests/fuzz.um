// ----------------------------------------------------------------------------

fn section_closure_gc() {
    banner("closure gc")

    closures := []fn(): int{}
    for i := 0; i < 500; i++ {
        box := new(int)
        box^ = i * 3
        closures = append(closures, fn (): int |box| { return box^ })
    }
    sum := 0
    for _, f in closures {
        sum += f()
    }
    expected := 0
    for i := 0; i < 500; i++ {
        expected += i * 3
    }
    check(sum == expected, "closure gc sum")

    printf("closure gc: OK\n")
}

