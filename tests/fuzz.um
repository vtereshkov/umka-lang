    mm["b"] = map[str]int{"x": 10, "y": 20}
    mm["c"] = map[str]int{"x": 100, "y": 200}

    check(mm["a"]["x"] == 1, "mm a x")
    check(mm["b"]["y"] == 20, "mm b y")
    check(mm["c"]["x"] == 100, "mm c x")

    mm["a"]["z"] = 999
