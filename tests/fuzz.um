// Section 48: stress big map then drop
// ----------------------------------------------------------------------------

fn section_big_map_drop() {
    banner("big map drop")

    m := make(map[int]str)
    for i := 0; i < 10000; i++ {
        m[i] = sprintf("v%d", i)
    }
    check(len(m) == 10000, "big map len")
    check(m[1234] == "v1234", "big map lookup")

    m = make(map[int]str)
    check(len(m) == 0, "big map dropped")

    printf("big map drop: OK\n")
}

// ----------------------------------------------------------------------------
// Section 49: stats sanity
// ----------------------------------------------------------------------------

fn section_stats() {
    banner("stats")

    srand(53)
    for trial := 0; trial < 50; trial++ {
        n := randRange(1, 1000)
        xs := make([]real, n)
        for i in xs {
            xs[i] = randReal() / 1e3
        }
        s := 0.0
        for _, x in xs {
            s += x
        }
        avg := s / real(n)

        d := 0.0
        for _, x in xs {
            d += x - avg
        }
        check(fabs(d) < 1e-3 * (1.0 + fabs(s)), "mean-deviation zero")
    }

    printf("stats: OK\n")
}

// ----------------------------------------------------------------------------
// Section 50: cleanup-like via closures
// ----------------------------------------------------------------------------

fn section_cleanup() {
    banner("cleanup-like")

    state := new(int)
    state^ = 0

    cleanup := fn () |state| {
        state^ = -1
    }

    {
        state^ = 100
        check(state^ == 100, "during work")
        cleanup()
    }
    check(state^ == -1, "cleanup ran")

    printf("cleanup-like: OK\n")
}

// ----------------------------------------------------------------------------
// Section 51: re-entrant recursion with closure
// ----------------------------------------------------------------------------

fn section_recursive_closure() {
    banner("recursive closure")

    fact_ptr := new(fn(n: int): int)
    fact_ptr^ = fn (n: int): int |fact_ptr| {
        if n <= 1 {
            return 1
        }
        return n * fact_ptr^(n - 1)
    }

    check(fact_ptr^(5) == 120, "rec closure fact 5")
    check(fact_ptr^(10) == 3628800, "rec closure fact 10")

    // Break the self-reference cycle so the reference-counted GC can reclaim it.
    fact_ptr^ = fn (n: int): int { return 0 }

    printf("recursive closure: OK\n")
}

