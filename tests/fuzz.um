// ----------------------------------------------------------------------------
// Section 69: nested closures referencing outer's parameter
// ----------------------------------------------------------------------------

fn section_nested_closure_param() {
    banner("nested closure param")

    chain := fn (start: int): fn(): int {
        n := new(int)
        n^ = start
        return fn (): int |n| {
            r := n^
            n^ *= 2
            return r
        }
    }

    f := chain(3)
    check(f() == 3, "chain start")
    check(f() == 6, "chain doubled")
    check(f() == 12, "chain doubled again")
    check(f() == 24, "chain doubled 3")

    printf("nested closure param: OK\n")
}

// ----------------------------------------------------------------------------
// Section 70: fiber inside closure
// ----------------------------------------------------------------------------

fn section_fiber_in_closure() {
    banner("fiber in closure")

    counts := new([]int)
    counts^ = []int{}

    spawn := fn (k: int) |counts| {
        out := new(int)
        out^ = -1
        kc := new(int)
        kc^ = k
        f := make(fiber, |out, kc| {
            for i := 0; i < kc^; i++ {
                out^ = i
                resume()
            }
            out^ = -1
        })
        for true {
            resume(f)
            if out^ < 0 {
                break
            }
            counts^ = append(counts^, out^)
            out^ = -1
        }
    }

    spawn(3)
    spawn(5)
    spawn(2)

    expected := []int{0, 1, 2, 0, 1, 2, 3, 4, 0, 1}
    check(len(counts^) == len(expected), "fiber in closure len")
    for i, v in counts^ {
        check(v == expected[i], "fiber in closure value")
    }

    printf("fiber in closure: OK\n")
}

