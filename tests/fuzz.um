// ----------------------------------------------------------------------------
// Section 55: slice of structs - sort by field
// ----------------------------------------------------------------------------

type Pair = struct {
    k: int
    v: str
}

fn section_struct_slice_sort() {
    banner("struct slice sort")

    srand(59)
    items := make([]Pair, 50)
    for i in items {
        items[i] = Pair{k: int(rand32() % 1000), v: sprintf("v%d", i)}
    }

    for i := 1; i < len(items); i++ {
        for j := i; j > 0 && items[j - 1].k > items[j].k; j-- {
            items[j - 1], items[j] = items[j], items[j - 1]
        }
    }

    for i := 1; i < len(items); i++ {
        check(items[i - 1].k <= items[i].k, "struct sorted by k")
    }

    printf("struct slice sort: OK\n")
}

// ----------------------------------------------------------------------------
// Section 56: continue/break in loops
// ----------------------------------------------------------------------------

fn section_break_continue() {
    banner("break/continue")

    sumEven := 0
    for i := 0; i < 100; i++ {
        if i % 2 != 0 {
            continue
        }
        sumEven += i
    }
    expected := 0
    for i := 0; i < 100; i++ {
        if i % 2 == 0 {
            expected += i
        }
    }
    check(sumEven == expected, "continue evens")

    firstDiv7 := -1
    for i := 1; i < 100; i++ {
        if i % 7 == 0 {
            firstDiv7 = i
            break
        }
    }
    check(firstDiv7 == 7, "break first div 7")

    cnt := 0
    for i := 0; i < 10; i++ {
        for j := 0; j < 10; j++ {
            if j == 5 {
                break
            }
            cnt++
        }
    }
    check(cnt == 50, "inner break count")

    printf("break/continue: OK\n")
}

